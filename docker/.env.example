# ── Database ──────────────────────────────────
POSTGRES_PASSWORD=changeme_use_strong_password

# ── JWT ───────────────────────────────────────
JWT_SECRET=changeme_generate_random_64_char_string

# ── Internal API Key (shared between business + cv-engine) ─
INTERNAL_API_KEY=changeme_generate_random_string

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── CV Engine ─────────────────────────────────
MODEL_PATH=/app/models/box_model.pt

# ── NVR (optional — can also configure via UI) ─
NVR_HOST=192.168.1.35
NVR_USER=changeme
NVR_PASS=changeme

# ── Super Admin ───────────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=changeme_use_strong_password
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ── Admin Seed ────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_use_strong_password
ADMIN_EMAIL=admin@yourdomain.com

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1
